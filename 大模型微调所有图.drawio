        <mxCell id="fWfy_zopAMzZ9MZUP1sN-47" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=20;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="第一条样本：&lt;div&gt;target_labels :[12,23,34,101,222]&lt;/div&gt;&lt;div&gt;token_probs: [&lt;/div&gt;&lt;div&gt;[],&lt;/div&gt;&lt;div&gt;[],&lt;/div&gt;&lt;div&gt;[],&lt;/div&gt;&lt;div&gt;[],&lt;/div&gt;&lt;div&gt;[]&lt;/div&gt;&lt;div&gt;]&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="310" x="-599" y="2022" as="geometry" />
        </mxCell>
        <mxCell id="fWfy_zopAMzZ9MZUP1sN-49" parent="1" style="whiteSpace=wrap;html=1;sketch=1;hachureGap=4;jiggle=2;curveFitting=1;fontFamily=Architects Daughter;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DArchitects%2BDaughter;" value="2" vertex="1">
